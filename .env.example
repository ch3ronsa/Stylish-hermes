# =============================================
# Stylish Hermes - Environment Configuration
# =============================================
# Copy this file to ~/.hermes/.env and fill in your keys.
# Run: python3 scripts/validate-config.py to check.

# --- REQUIRED ---
TELEGRAM_BOT_TOKEN=your-telegram-bot-token

# --- VISION / CHAT (at least one required) ---
GLM_API_KEY=your-glm-api-key
GLM_BASE_URL=https://api.z.ai/api/coding/paas/v4
AUXILIARY_VISION_PROVIDER=main
AUXILIARY_VISION_MODEL=glm-4.6v-flash
# OPENROUTER_API_KEY=sk-or-...  # alternative to GLM

# --- IMAGE GENERATION (at least one required) ---
# Fallback order: FAL -> OpenAI -> Gemini
FAL_KEY=your-fal-key
OPENAI_API_KEY=your-openai-api-key
GEMINI_API_KEY=your-gemini-api-key

